@font-face{font-family:"Atkinson Hyperlegible Next";font-style:normal;font-display:swap;font-weight:400;src:url("/fonts/atkinson-hyperlegible-next-regular.woff2") format("woff2")}@font-face{font-family:"LINE Seed Sans";font-style:normal;font-display:swap;font-weight:700;src:url("/fonts/line-seed-sans-bold.woff2")}@keyframes fadeInUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}*,*::after,*::before{box-sizing:inherit}*::selection{background:#dfdad9}html{box-sizing:border-box}body{color:#575279;background-color:#faf4ed;font-family:"Atkinson Hyperlegible Next",sans-serif;font-size:1.1rem;line-height:1.7}body ul{padding:0;margin:0;list-style-type:none}body h1,body h2,body h3,body h4{font-family:"LINE Seed Sans",sans-serif}body h1{font-size:clamp(1.75rem,5vw,2.75rem)}body h2{font-size:clamp(1.5rem,4vw,2rem)}body h3{font-size:clamp(1.35rem,3.5vw,1.75rem)}body h4{font-size:clamp(1.25rem,3vw,1.5rem)}body h5{font-size:clamp(1.15rem,2vw,1.25rem)}body h6{font-size:1rem}body p{margin:0}a{color:#575279;text-decoration:none}header{max-width:100%;padding:0 70px 0 70px;margin:2vw auto;display:flex;align-items:center;text-align:center}header .left{flex:1;justify-content:flex-start;text-align:start}header .left .header-title{font-family:"LINE Seed Sans",sans-serif;font-size:2rem;text-transform:uppercase}header nav{flex:1;justify-content:flex-end;text-align:end}header nav .right{display:flex;justify-content:end;gap:18px}header nav .right li{padding:.8rem;border-radius:.75rem}header nav .right li:hover{background-color:#f2e9e1;transition-duration:500ms}header nav .right li:has(a:focus),header nav .right li:has(a:active){box-shadow:0 0 2px 2px #56949f;transition-timing-function:cubic-bezier(0.25, 0.46, 0.45, 0.94);transition-duration:.15s}footer{display:flex;flex-direction:column;width:100%;max-width:50%;padding:3rem 0;margin:auto;align-items:center;gap:16px}footer .social-line{display:flex;justify-content:center;align-items:center;gap:20px}footer .social-line svg{width:32px;height:32px;transition:ease .7s}footer .social-line svg:hover{transform:translateY(-10px)}.home-intro{max-width:69vw;margin:10rem auto 10rem auto;text-align:center;animation:fadeInUp .3s ease-in}.projects-section{max-width:1280px;padding-left:1.5rem;padding-right:1.5rem;margin:auto}.projects-section li{opacity:0;transform:translateY(60px);transition:opacity .8s ease,transform .8s ease}.projects-section li.fade-in-visible{opacity:1;transform:translateY(0)}.projects-section li a{display:block;padding:2rem 1.5rem;border-radius:.75rem;background-color:#fffaf3}.projects-section li a .project-image{overflow:hidden}.projects-section li a .project-image img{width:100%;border-radius:.25rem;object-fit:cover;transition:ease 450ms}.projects-section li a .project-image img:hover{transform:scale3d(1.05, 1.05, 1)}.projects-section li a:hover{background-color:#f2e9e1;transition-timing-function:cubic-bezier(0.445, 0.05, 0.55, 0.95);transition-duration:.25s}.projects-section li a:focus{box-shadow:0 0 2px 2px #56949f;transition-timing-function:cubic-bezier(0.25, 0.46, 0.45, 0.94);transition-duration:.15s}.projects-section li+li{margin-top:80px}.projects-section h3{margin-top:4px;margin-bottom:6px}.projects-section p{margin:0}.about-section{text-align:center;word-break:break-all;margin:auto;animation:fadeInUp .4s ease}.about-section article{margin:auto;text-align:left;max-width:800px;padding:0 1em;word-break:keep-all}.about-section article p+p{margin-top:16px}.page-404{text-align:center;margin:auto;padding-top:3rem;padding-bottom:3rem}.page-404 pre{margin:0 auto;transform:scale(0.8)}.page-404 span{font-family:"LINE Seed Sans",sans-serif;font-size:5rem}